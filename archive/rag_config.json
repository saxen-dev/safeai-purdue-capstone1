{
  "embedding": {
    "primary_model": "pritamdeka/S-PubMedBert-MS-MARCO",
    "comparison_model": "BAAI/bge-m3",
    "primary_dim": 768,
    "comparison_dim": 1024,
    "batch_size": 32,
    "comparison_modes": ["child_level", "parent_level"]
  },
  "chunking": {
    "child_max_tokens": 512,
    "child_overlap_tokens": 50,
    "child_min_tokens": 50,
    "tables_keep_atomic": true,
    "create_nll_children": true,
    "token_multiplier": 1.3,
    "adaptive_rules": {
      "dosing_table": {"strategy": "atomic_plus_nll", "max_tokens": null},
      "clinical_table": {"strategy": "atomic", "max_tokens": null},
      "evidence_table": {"strategy": "atomic", "max_tokens": null},
      "other_table": {"strategy": "atomic", "max_tokens": null},
      "narrative_verbatim": {"strategy": "proposition_decomposition", "max_tokens": 200},
      "narrative_high": {"strategy": "adaptive_small", "max_tokens": 400},
      "narrative_standard_large": {"strategy": "recursive_paragraph", "max_tokens": 512, "overlap": 50},
      "narrative_standard_small": {"strategy": "passthrough", "max_tokens": null},
      "image_ocr": {"strategy": "passthrough", "max_tokens": null},
      "structural_table": {"strategy": "skip", "max_tokens": null}
    },
    "contextual_header_template": "[Context: {section_title} | {condition} | {drug_name} | Source: {document_title} Section {section_number}, p.{source_pages}]"
  },
  "vector_db": {
    "chromadb_persist_dir": "rag_output/chroma_db",
    "faiss_index_path": "rag_output/faiss_index_hnsw_pq8.bin",
    "faiss_flat_index_path": "rag_output/faiss_index_flat.bin",
    "collection_name": "brain1_clinical_guidelines",
    "faiss_hnsw_m": 32,
    "faiss_hnsw_ef_construction": 200,
    "faiss_hnsw_ef_search": 100,
    "faiss_pq_m": 96,
    "faiss_pq_nbits": 8,
    "faiss_ivf_nlist": 64
  },
  "retrieval": {
    "top_k_initial": 20,
    "top_k_fused": 10,
    "top_k_final": 5,
    "rrf_k": 60,
    "reranker_model": "cross-encoder/ms-marco-MiniLM-L-6-v2",
    "reranker_enabled": true,
    "reranker_threshold": 0.1,
    "expand_context": true,
    "max_context_chunks": 3
  },
  "paths": {
    "chunks_input": "extraction_output_malaria/chunks.json",
    "output_dir": "rag_output",
    "brain1_package_dir": "rag_output/brain1_package",
    "child_chunks_path": "rag_output/child_chunks.json",
    "parent_chunks_path": "rag_output/parent_chunks.json",
    "bm25_corpus_path": "rag_output/bm25_corpus.json",
    "embeddings_primary_path": "rag_output/embeddings_pubmedbert.npy",
    "embeddings_comparison_path": "rag_output/embeddings_bgem3.npy",
    "build_report_path": "rag_output/build_report.json",
    "test_results_path": "rag_output/retrieval_test_results.json"
  }
}
